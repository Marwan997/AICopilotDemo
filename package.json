{
  "name": "server-dashboard-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode pages",
    "build:monitoring": "tsc -b && vite build --mode monitoring",
    "serve": "npm run build && node server/static-server.js",
    "serve:8080": "npm run build && node server/static-server.js",
    "serve:preview": "vite preview --host 127.0.0.1 --port 5173 --strictPort",
    "serve:api": "node --experimental-strip-types server/index.ts",
    "serve:monitoring": "npm run build:monitoring && node server/static-server.js",
    "dev:monitoring": "vite --host 127.0.0.1 --port 8081 --strictPort --open /monitoring.html",
    "deploy": "npm run build:pages",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1 --port 5173 --strictPort"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
